const vi = Number(prompt("Ingresa la velocidad inicial"));
const a = Number(prompt("Ingresa la aceleración "));
const d = Number(prompt("Ingresa la distancia "));

const calculo = (vi * vi) + (2 * a * d);

if (a != 0) {
  const tiempo = (-vi + (calculo * 0.5)) / a;
  document.write("El tiempo es: " + tiempo + " segundos");
} else {
  const tiempoSimple = d / vi;
  document.write("El tiempo sin aceleración es: " + tiempoSimple);
}
